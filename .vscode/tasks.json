{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Jekyll: Start (Docker)",
            "type": "shell",
            "command": "docker compose up",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Jekyll: Stop (Docker)",
            "type": "shell",
            "command": "docker compose down",
            "group": "build",
            "problemMatcher": []
        }
    ]
}